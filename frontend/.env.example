# Backend API URL
VITE_API_URL=http://localhost:5000

# Cloudinary (for blog image/video/PDF uploads)
# 1. Sign up free at cloudinary.com
# 2. Copy your Cloud Name from the dashboard
# 3. Create an "Upload Preset" (Settings → Upload → Add preset → Unsigned)
VITE_CLOUDINARY_CLOUD=your_cloud_name
VITE_CLOUDINARY_PRESET=your_upload_preset
